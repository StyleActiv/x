# Configuración para favicons y archivos estáticos
# Asegurar que los favicons se sirvan con los headers correctos

# Configuración de tipos MIME para favicons
<IfModule mod_mime.c>
    AddType image/x-icon .ico
    AddType image/png .png
    AddType application/json .json
</IfModule>

# Headers de caché para favicons
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType application/json "access plus 1 month"
</IfModule>

# Headers de seguridad
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Redirección para favicon.ico si no existe
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^favicon\.ico$ favicon-32x32.png [L]

# Configuración para archivos de manifest
<Files "manifest.json">
    Header set Content-Type "application/manifest+json"
</Files>
